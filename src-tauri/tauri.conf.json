{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AHK Manager",
  "version": "0.1.0",
  "identifier": "com.ahkmanager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AHK Manager",
        "width": 1180,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "decorations": false,
        "resizable": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {},
      "nsis": {}
    }
  }
}
